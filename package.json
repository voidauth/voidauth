{
  "name": "voidauth",
  "main": "server/index.ts",
  "type": "module",
  "engines": {
    "node": ">=24.18.x"
  },
  "scripts": {
    "start": "concurrently -n api,web -c green,blue \"npm run server:watch\" \"npm run frontend:watch\"",
    "server:watch": "nodemon --ext \"ts,js,json\" --watch server/ --watch shared/ --exec \"tsc && npm run server:build && tsx --env-file-if-exists=.env ./server/index.ts\"",
    "server:build": "tsx ./esbuild.config.ts",
    "frontend:watch": "cd frontend && npm run watch",
    "postinstall": "husky",
    "lint": "eslint",
    "prettier": "prettier --write \"**/*\""
  },
  "author": "Derek Paschal",
  "license": "SEE LICENSE IN LICENSE FILE",
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@angular-devkit/schematics": "^22.0.6",
    "@angular/material": "^22.0.4",
    "@simplewebauthn/server": "^13.3.2",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "@zxcvbn-ts/language-en": "^4.1.1",
    "better-sqlite3": "^12.11.1",
    "dockerode": "^5.0.1",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "husky": "^9.1.7",
    "jose": "^6.2.3",
    "knex": "^3.3.0",
    "matcher": "^6.0.0",
    "nodemailer": "^9.0.3",
    "oidc-provider": "^9.9.1",
    "otpauth": "^9.5.1",
    "pg": "^8.22.0",
    "psl": "^1.15.0",
    "pug": "^3.0.4",
    "sass": "^1.101.0",
    "tsx": "^4.23.1",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/dockerode": "^4.0.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/madge": "^5.0.3",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/oidc-provider": "^9.5.0",
    "@types/psl": "^1.1.3",
    "@types/pug": "^2.0.10",
    "@types/yargs": "^17.0.35",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  }
}
